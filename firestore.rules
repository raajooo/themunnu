rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, phoneNumber, displayName, addresses, role, createdAt
    //
    // Collection: products
    // Fields: id, name, brand, price, description, images, sizes, stock, category, isLimited, isTrending, isFeatured, createdAt
    //
    // Collection: orders
    // Fields: id, userId, items, totalAmount, paymentMethod, paymentStatus, orderStatus, address, trackingId, deliveryEstimate, createdAt
    //
    // Collection: settings
    // Fields: razorpayKeyId, razorpayKeySecret, fast2smsApiKey, delhiveryApiKey, isCodEnabled
    //
    // Collection: categories
    // Fields: id, name, slug, createdAt
    //
    // Collection: reviews
    // Fields: id, productId, userId, userName, rating, comment, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         request.auth.token.email == "raajooothakur0@gmail.com" ||
         request.auth.token.email == "9193731911@munnu.com" ||
         request.auth.token.phone_number == "+919193731911");
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.role in ['user', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if true; // Allow everyone to check if phone/email exists during registration
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                      isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || 
                       request.auth.token.email == "raajooothakur0@gmail.com" ||
                       request.auth.token.email == "9193731911@munnu.com" ||
                       request.auth.token.phone_number == "+919193731911");
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'reviewCount']));
      allow create, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Allow everyone to read settings (like isCodEnabled, isCouponSystemEnabled)
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow get: if true;
      allow list: if true; // Allow checking for active coupons for the shop banner
      allow update: if (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount', 'totalDiscountGenerated'])) || isAdmin();
      allow create, delete: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subscribers/{subscriberId} {
      allow create: if true; // Allow anyone to subscribe
      allow read, update, delete: if isAdmin();
    }

    match /coupon_usage/{usageId} {
      allow read: if isAuthenticated() && (usageId.startsWith(request.auth.uid) || isAdmin());
      allow write: if isAuthenticated() && (usageId.startsWith(request.auth.uid) || isAdmin());
    }
  }
}
