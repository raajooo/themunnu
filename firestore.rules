rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, phoneNumber, displayName, addresses, role, createdAt
    //
    // Collection: products
    // Fields: id, name, brand, price, description, images, sizes, stock, category, isLimited, isTrending, isFeatured, createdAt
    //
    // Collection: orders
    // Fields: id, userId, items, totalAmount, paymentMethod, paymentStatus, orderStatus, address, trackingId, deliveryEstimate, createdAt
    //
    // Collection: settings
    // Fields: razorpayKeyId, razorpayKeySecret, fast2smsApiKey, delhiveryApiKey, isCodEnabled
    //
    // Collection: categories
    // Fields: id, name, slug, createdAt
    //
    // Collection: reviews
    // Fields: id, productId, userId, userName, rating, comment, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         request.auth.token.phone_number == "+919193731911" ||
         request.auth.token.phone_number == "9193731911" ||
         (request.auth.token.email == "raajooothakur0@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'phoneNumber', 'role']) &&
             data.role in ['user', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'reviewCount']));
      allow create, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
